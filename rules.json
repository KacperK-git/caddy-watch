    "window": 60,
    "ban_duration": 7776000,
    "description": "XXE / XML External Entity probe",
    "tags": ["exploit", "xxe"]
  },
  {
    "field": "request.uri",
    "pattern": "(?i)(/phpinfo\\.php|/info\\.php|/test\\.php|/pma/)",
    "threshold": 1,
    "window": 60,
    "ban_duration": 7776000,
    "description": "Info disclosure probes (phpinfo, phpMyAdmin)",
    "tags": ["scan", "uri"]
  },
  {
    "field": "request.uri",
    "pattern": "(?i)(/server-status|/nginx_status|/php-fpm-status|/status\\?full|/actuator/health)",
    "threshold": 1,
    "window": 60,
    "ban_duration": 7776000,
    "description": "Server status & health endpoint probes",
    "tags": ["scan", "uri"]
  }
]
